# Copy this to .env.local and fill in values

NEXT_PUBLIC_SITE_URL=https://desertfathersstudio.com
NEXT_PUBLIC_WHOLESALE_URL=https://wholesale.desertfathersstudio.com
NEXT_PUBLIC_ADMIN_URL=https://admin.desertfathersstudio.com

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@desertfathersstudio.com

# Wholesale portal session signing — generate with: openssl rand -hex 32
WHOLESALE_SESSION_SECRET=

# Admin API key for order management (PATCH /api/wholesale/orders/[id])
# Generate with: openssl rand -hex 32
ADMIN_SECRET_KEY=

# Supabase direct DB connection string — for pg_dump backups only
# Get from: Supabase Dashboard → Project Settings → Database → Connection string (URI)
SUPABASE_DB_URL=
